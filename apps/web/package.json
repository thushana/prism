{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app",
    "format": "prettier --write \"app/**/*.{ts,tsx}\" \"*.{ts,tsx}\" \"*.{js,mjs}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=database/drizzle.config.ts",
    "db:push": "drizzle-kit push --config=database/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=database/drizzle.config.ts",
    "db:seed": "tsx database/seed.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "authentication": "workspace:*",
    "database": "workspace:*",
    "dotenv": "^17.4.2",
    "feature-flags": "workspace:*",
    "flags": "^4.0.6",
    "admin": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "intelligence": "workspace:*",
    "logger": "workspace:*",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ui": "workspace:*",
    "@prism/utilities": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "commander": "^14.0.3",
    "drizzle-kit": "^0.31.10",
    "@eslint/compat": "^2.0.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "lightningcss": "^1.32.0",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
