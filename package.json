{
  "name": "@prism/core",
  "version": "0.1.0",
  "description": "Prism Core - Foundational infrastructure for Next.js applications with TypeScript, Tailwind CSS, Drizzle ORM, and AI capabilities",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "keywords": [
    "nextjs",
    "typescript",
    "tailwindcss",
    "drizzle-orm",
    "vitest",
    "starter",
    "template",
    "monorepo"
  ],
  "engines": {
    "node": ">=25.0.0"
  },
  "bin": {
    "prism": "./tools/app/tools.mjs"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "build:web": "pnpm --filter web run build",
    "clean": "rm -rf js scripts/*.js *.tsbuildinfo apps/*/.next apps/*/node_modules/.cache",
    "clean:directories": "tsx scripts/clean-directories.ts",
    "database:generate": "drizzle-kit generate --config=packages/database/drizzle.config.ts",
    "database:migrate": "drizzle-kit migrate --config=packages/database/drizzle.config.ts",
    "database:push": "drizzle-kit push --config=packages/database/drizzle.config.ts",
    "database:studio": "drizzle-kit studio --config=packages/database/drizzle.config.ts",
    "dev": "pnpm run dev:kill && pnpm run dev:web",
    "dev:all": "pnpm run dev",
    "dev:kill": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true; pkill -f 'tsc --watch' 2>/dev/null || true; pkill -f 'next dev' 2>/dev/null || true; echo 'Killed all dev servers'",
    "dev:setup": "./scripts/setup-hosts.sh",
    "dev:web": "pnpm --filter web run dev",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json}\" \"packages/**/*.{ts,tsx,json}\" \"docs/**/*.md\" \"*.{js,mjs,json}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json}\" \"packages/**/*.{ts,tsx,json}\" \"docs/**/*.md\" \"*.{js,mjs,json}\"",
    "lint": "eslint \"packages/*/source/**/*.{ts,tsx}\" \"packages/*/components/**/*.{ts,tsx}\" \"packages/*/styles/**/*.{ts,tsx}\" \"apps/*/app/**/*.{ts,tsx}\" \"apps/*/config/**/*.{ts,tsx}\" \"tools/app/**/*.ts\"",
    "lint:fix": "eslint \"packages/*/source/**/*.{ts,tsx}\" \"packages/*/components/**/*.{ts,tsx}\" \"packages/*/styles/**/*.{ts,tsx}\" \"apps/*/app/**/*.{ts,tsx}\" \"apps/*/config/**/*.{ts,tsx}\" \"tools/app/**/*.ts\" --fix",
    "precommit": "pnpm run build",
    "prepare": "node -e \"if (!process.env.CI && !process.env.VERCEL) { try { require('husky').install() } catch { process.exit(0) } }\"",
    "prism": "pnpm --filter tools run start --",
    "prism:sync": "tsx scripts/sync.ts",
    "setup": "pnpm link --global && pnpm run prism:sync",
    "prism:sync:commands": "tsx scripts/sync-commands.ts",
    "prism:sync:git": "tsx scripts/sync-git.ts",
    "prism:sync:scripts": "tsx scripts/sync-scripts.ts",
    "generate:colors": "pnpm --filter ui run generate:colors",
    "quality": "tsx scripts/quality.ts",
    "quality:quick": "pnpm run format && pnpm run lint && pnpm run typecheck",
    "start": "pnpm -r --if-present run start",
    "start:web": "pnpm --filter web run start",
    "test": "pnpm -r --if-present run test",
    "test:coverage": "pnpm --filter web run test:coverage",
    "test:run": "tsx scripts/test-workspaces.ts",
    "test:ui": "pnpm --filter web run test:ui",
    "tools": "pnpm --filter tools run start --",
    "typecheck": "tsx scripts/typecheck-workspaces.ts",
    "vercel:build": "vercel build",
    "vercel:build:web": "vercel build --cwd apps/web",
    "vercel:test:web": "pnpm --filter web run build",
    "watch": "tsc --watch"
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tools/**/*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "lightningcss": "^1.32.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "@eslint/compat": "^2.0.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.27.2",
      "next": "16.2.4",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "exports": {
    "./ui": "./packages/ui/source/index.ts",
    "./database": "./packages/database/source/index.ts",
    "./intelligence": "./packages/intelligence/source/index.ts",
    "./logger": "./packages/logger/source/index.ts",
    "./utilities": "./packages/utilities/source/index.ts",
    "./admin": "./packages/admin/source/index.ts",
    "./authentication": "./packages/authentication/source/index.ts",
    "./charts": "./packages/charts/source/index.ts"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  }
}
